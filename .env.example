# Claude Session Manager — Environment Variables
# Claude 会话管理器 — 环境变量

# Server port (default: 3727)
CSM_PORT=3727

# Bind address (default: 0.0.0.0)
CSM_HOST=0.0.0.0

# JWT signing secret (auto-generated if empty)
# JWT 签名密钥（留空则自动生成）
CSM_SECRET=

# Path to .claude directory (default: ~/.claude)
# CSM_CLAUDE_DIR=/home/youruser/.claude

# JWT token expiry (default: 24h)
# CSM_JWT_EXPIRY=24h

# Read-only mode — disables delete operations
# 只读模式 — 禁用删除操作
# CSM_READ_ONLY=true

# Debug logging
# CSM_DEBUG=true
